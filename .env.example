# Salin ke .env untuk pengembangan lokal (file .env tidak di-commit ke GitHub).

# Folder penyimpanan model ML (default: ./saved_models)
# STOCK_ML_MODEL_DIR=./saved_models

# WebSocket feed resmi IDX/broker (opsional)
# IDX_OFFICIAL_WS_URL=wss://vendor.example/stream
# IDX_OFFICIAL_WS_TOKEN=
# IDX_OFFICIAL_WS_SUBPROTOCOL=
